# Copy this file to .env  (cp .env.example .env)

# Postgres (matches docker-compose.yml). In production DATABASE_URL points at PgBouncer.
DATABASE_URL="postgresql://wfm:wfm@localhost:5432/wfm?schema=public"
DIRECT_DATABASE_URL="postgresql://wfm:wfm@localhost:5432/wfm?schema=public"

# Redis (BullMQ queues + Socket.IO)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# App
PORT="3000"
WEB_ORIGIN="*"
JWT_SECRET="dev-secret-change-me"

# IdleTracker desktop agent (separate repo: idle-tracker).
# Shared fleet key the agents send as `x-agent-key` on POST /idle-events.
# Leave unset to disable idle ingestion entirely.
IDLE_AGENT_KEY=""
# Server-side minimum idle time (seconds) before an idle_start report
# auto-clocks-out a floor employee. Keep the agents' idle_threshold_seconds
# equal to this.
IDLE_CLOCKOUT_SECONDS="300"
